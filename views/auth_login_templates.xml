<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="custom_login_with_otp" inherit_id="web.login" name="Login with OTP Block">
        <xpath expr="//form[contains(@class, 'oe_login_form')]" position="inside">
            <div class="mt-4 pt-3 border-top" id="custom_otp_login_box">
                <h5 class="mb-3">Login with OTP</h5>

                <div class="mb-2">
                    <input type="text"
                           id="otp_mobile"
                           class="form-control"
                           placeholder="Enter mobile number"/>
                </div>

                <div class="mb-2 d-flex gap-2">
                    <button type="button"
                            class="btn btn-outline-primary"
                            id="btn_send_otp">
                        Send OTP
                    </button>
                </div>

                <div class="mb-2">
                    <input type="text"
                           id="otp_code"
                           class="form-control"
                           placeholder="Enter OTP code"/>
                </div>

                <div class="mb-2 d-flex gap-2">
                    <button type="button"
                            class="btn btn-primary"
                            id="btn_verify_otp">
                        Verify OTP
                    </button>
                </div>

                <div id="otp_status"
                     class="alert d-none mt-3"
                     role="alert"></div>
            </div>
        </xpath>
    </template>

    <template id="otp_login_success_page" name="OTP Login Success Page">
        <t t-call="web.login_layout">
            <div class="oe_login_form">
                <h3 class="mb-3">OTP verified</h3>
                <p class="mb-2">
                    Mobile:
                    <strong t-esc="otp_mobile"/>
                </p>
                <p class="mb-4">
                    User ID:
                    <strong t-esc="otp_user_id"/>
                </p>
                <div class="alert alert-info">
                    Verification succeeded. Next, we wire this to final session login.
                </div>
                <a href="/web/login" class="btn btn-secondary">Back to login</a>
            </div>
        </t>
    </template>
</odoo>